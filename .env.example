# ============================================================
#  NestMatch Environment Variables
#  
#  1. Copy this file → rename to: .env.local
#  2. Fill in your real Supabase values
#  3. Add these same variables in Vercel Dashboard → Settings → Environment Variables
#  4. NEVER commit .env.local to GitHub
# ============================================================

# Supabase — find these at: supabase.com → your project → Settings → API
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_ANON_KEY_HERE

# App URL (update after Vercel deploys)
VITE_APP_URL=https://nestmatch.vercel.app

# Optional: Stripe (add when setting up payments)
# VITE_STRIPE_KEY=pk_live_YOUR_KEY
